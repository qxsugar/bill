.avatar-wrap { display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; overflow: hidden; background: var(--color-primary); }
.size-small { width: 60rpx; height: 60rpx; }
.size-medium, .avatar-wrap { width: 80rpx; height: 80rpx; }
.size-large { width: 160rpx; height: 160rpx; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { color: #fff; font-size: var(--font-size-base); font-weight: bold; }
