.avatar-wrap { display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; overflow: hidden; background: var(--gradient-primary); }
.size-small { width: 60rpx; height: 60rpx; }
.size-medium, .avatar-wrap { width: 84rpx; height: 84rpx; }
.size-large { width: 160rpx; height: 160rpx; }
.avatar-img { width: 100%; height: 100%; }
.avatar-emoji { font-size: 44rpx; line-height: 1; }
.size-large .avatar-emoji { font-size: 88rpx; }
.size-small .avatar-emoji { font-size: 32rpx; }
.avatar-placeholder { color: #fff; font-size: var(--font-size-base); font-weight: 700; }
.size-large .avatar-placeholder { font-size: var(--font-size-xxl); }
