<view class="popup-mask" wx:if="{{visible}}" bindtap="close">
  <view class="popup-content" catchtap>
    <view class="sheet-handle"></view>
    <view class="popup-header">
      <text class="popup-close" bindtap="close">取消</text>
      <text class="popup-title">
        {{mode === 'single' ? '向 ' + (targets[0].nickname || '') + ' 支出' : '支出'}}
      </text>
      <view class="popup-confirm" bindtap="submit">
        <icon name="check" size="32" color="#3B5BDB" />
        <text>确认</text>
      </view>
    </view>

    <!-- 批量模式：均分 / 统一 切换 -->
    <view wx:if="{{mode === 'batch'}}" class="batch-modes">
      <view class="mode-tab {{batchMode === 'equal' ? 'active' : ''}}" data-mode="equal" bindtap="switchBatchMode">均分金额</view>
      <view class="mode-tab {{batchMode === 'same' ? 'active' : ''}}" data-mode="same" bindtap="switchBatchMode">统一金额</view>
    </view>

    <!-- 批量模式：展示参与的对象 -->
    <view wx:if="{{mode === 'batch'}}" class="targets">
      <block wx:for="{{targets}}" wx:key="user_id">
        <view class="target-item">
          <user-avatar info="{{item}}" size="small" />
          <text class="target-name">{{item.nickname}}</text>
        </view>
      </block>
    </view>

    <view class="form">
      <text class="amount-symbol">¥</text>
      <input
        class="amount-input"
        type="digit"
        focus="{{visible}}"
        placeholder="{{mode === 'batch' && batchMode === 'equal' ? '输入总金额' : '输入金额'}}"
        placeholder-class="amount-placeholder"
        bindinput="onAmountInput"
        value="{{amount}}"
      />
    </view>
  </view>
</view>
