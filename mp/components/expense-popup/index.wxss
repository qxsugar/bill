.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.5);
  display: flex; align-items: flex-end; z-index: 100;
}
.popup-content {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  width: 100%;
  padding: var(--spacing-base) var(--spacing-base) calc(var(--spacing-xl) + env(safe-area-inset-bottom));
}
.sheet-handle { width: 72rpx; height: 8rpx; border-radius: var(--radius-round); background: var(--color-border-strong); margin: 0 auto var(--spacing-base); }

.popup-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-base); }
.popup-title { font-size: var(--font-size-md); font-weight: 700; color: var(--color-text-primary); }
.popup-close { font-size: var(--font-size-base); color: var(--color-text-secondary); }
.popup-confirm { display: flex; align-items: center; gap: 4rpx; font-size: var(--font-size-base); color: var(--color-primary); font-weight: 600; }

.batch-modes { display: flex; gap: var(--spacing-sm); margin-bottom: var(--spacing-base); }
.mode-tab {
  flex: 1; text-align: center; padding: var(--spacing-sm);
  border-radius: var(--radius-base);
  background: var(--color-bg-sunken); color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  transition: background 0.2s ease, color 0.2s ease;
}
.mode-tab.active { background: var(--color-primary); color: #fff; font-weight: 600; }

.targets { display: flex; flex-wrap: wrap; gap: var(--spacing-base); margin-bottom: var(--spacing-base); }
.target-item { display: flex; flex-direction: column; align-items: center; gap: var(--spacing-xs); }
.target-name {
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
  max-width: 100rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.form {
  display: flex; align-items: center; gap: var(--spacing-sm);
  background: var(--color-bg-sunken);
  border-radius: var(--radius-base);
  padding: var(--spacing-base) var(--spacing-md);
}
.amount-symbol { font-size: var(--font-size-xl); font-weight: 700; color: var(--color-text-primary); }
.amount-input { flex: 1; font-size: var(--font-size-display); font-weight: 700; color: var(--color-text-primary); }
.amount-placeholder { font-size: var(--font-size-lg); font-weight: 400; color: var(--color-text-placeholder); }
