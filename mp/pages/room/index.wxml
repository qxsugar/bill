<view class="room">
  <!-- 成员横向列表，邀请好友固定最右 -->
  <view class="members-bar">
    <scroll-view class="members-scroll" scroll-x>
      <view class="members-inner">
        <block wx:for="{{members}}" wx:key="user_id">
          <view class="member" bindtap="onMemberTap" data-user-id="{{item.user_id}}">
            <user-avatar info="{{item}}" />
            <text class="member-name">{{item.nickname}}{{item.is_owner ? '(房主)' : ''}}</text>
            <text class="member-balance {{item.balance >= 0 ? 'earn' : 'lose'}}">{{item.balance >= 0 ? '+' : ''}}{{item.balance}}¥</text>
          </view>
        </block>
      </view>
    </scroll-view>
    <view class="invite-btn" bindtap="goInvite">
      <text class="invite-icon">＋</text>
      <text class="invite-label">邀请好友</text>
    </view>
  </view>

  <!-- 消息列表：从新到旧，自适应高度 -->
  <scroll-view class="messages" scroll-y>
    <block wx:for="{{messages}}" wx:key="id">
      <view class="message">
        <text class="message-text">{{item.text}}</text>
        <view class="message-actions">
          <text wx:if="{{item.canRevoke}}" class="msg-btn revoke" catchtap="onRevoke" data-id="{{item.id}}">撤销</text>
          <text wx:if="{{item.canThank}}" class="msg-btn thank" catchtap="onThank" data-id="{{item.id}}">感谢</text>
          <text wx:if="{{item.thanked}}" class="msg-tag">已感谢</text>
        </view>
      </view>
    </block>
    <view wx:if="{{messages.length === 0}}" class="empty">还没有支出记录</view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="action" bindtap="onExpenseTap"><text class="action-icon">💸</text><text>支出</text></view>
    <view class="action" bindtap="goLog"><text class="action-icon">📋</text><text>日志</text></view>
    <view class="action" bindtap="goCardTracker"><text class="action-icon">🃏</text><text>记牌器</text></view>
    <view class="action" bindtap="goProfile"><text class="action-icon">👤</text><text>修改</text></view>
    <view class="action" bindtap="goSettle"><text class="action-icon">🧮</text><text>结算</text></view>
    <view class="action" bindtap="onLeave"><text class="action-icon">🚪</text><text>离开</text></view>
  </view>

  <expense-popup
    visible="{{popupVisible}}"
    mode="{{popupMode}}"
    targets="{{popupTargets}}"
    bind:close="closePopup"
    bind:submit="onExpenseSubmit"
  />
</view>
