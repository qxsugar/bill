page { height: 100%; }
.room { display: flex; flex-direction: column; height: 100vh; background: var(--color-bg); }

/* 成员栏 */
.members-bar {
  display: flex; align-items: stretch;
  background: var(--color-bg-white);
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}
.members-scroll { flex: 1; overflow: hidden; }
.members-inner { display: flex; padding: var(--spacing-base) var(--spacing-sm); white-space: nowrap; gap: var(--spacing-md); }
.member { display: inline-flex; flex-direction: column; align-items: center; gap: 8rpx; min-width: 110rpx; }
.member-avatar { position: relative; }
.owner-badge {
  position: absolute; bottom: -6rpx; left: 50%; transform: translateX(-50%);
  background: var(--gradient-primary);
  color: #fff; font-size: 18rpx; line-height: 1;
  padding: 4rpx 10rpx; border-radius: var(--radius-round);
  white-space: nowrap;
  box-shadow: var(--shadow-sm);
}
.member-name {
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
  max-width: 110rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-top: 4rpx;
}
.member-balance { font-size: var(--font-size-sm); }

.invite-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: var(--spacing-sm) var(--spacing-base);
  gap: 8rpx; flex-shrink: 0;
}
.invite-icon {
  width: 76rpx; height: 76rpx;
  border-radius: var(--radius-base);
  background: var(--color-primary-soft);
  display: flex; align-items: center; justify-content: center;
}
.invite-label { font-size: var(--font-size-xs); color: var(--color-primary); }

/* 消息列表 */
.messages { flex: 1; overflow: hidden; padding: var(--spacing-base) var(--spacing-base) var(--spacing-sm); }
.message {
  background: var(--color-bg-white);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-base);
  margin-bottom: var(--spacing-sm);
  display: flex; justify-content: space-between; align-items: center; gap: var(--spacing-sm);
}
.message-text { font-size: var(--font-size-sm); color: var(--color-text-primary); flex: 1; line-height: 1.5; }
.message-actions { display: flex; gap: var(--spacing-xs); flex-shrink: 0; }
.msg-btn {
  display: flex; align-items: center; gap: 4rpx;
  font-size: var(--font-size-xs);
  padding: 8rpx 16rpx; border-radius: var(--radius-round);
}
.revoke { background: var(--color-danger-soft); color: var(--color-danger); }
.thank { background: var(--color-primary-soft); color: var(--color-primary); }
.msg-tag {
  display: flex; align-items: center; gap: 4rpx;
  font-size: var(--font-size-xs); color: var(--color-text-placeholder);
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  background: var(--color-bg-white);
  box-shadow: 0 -4rpx 24rpx rgba(31, 36, 48, 0.06);
  padding: var(--spacing-sm) 0;
  flex-shrink: 0;
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
}
.action {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
}
.action-icon { display: flex; align-items: center; justify-content: center; height: 48rpx; }
.action-accent { color: var(--color-primary); font-weight: 600; }
