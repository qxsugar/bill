page { height: 100%; }
.room { display: flex; flex-direction: column; height: 100vh; background: var(--color-bg); }

/* 成员栏 */
.members-bar { display: flex; align-items: stretch; background: var(--color-bg-white); border-bottom: 1rpx solid var(--color-border); flex-shrink: 0; }
.members-scroll { flex: 1; overflow: hidden; }
.members-inner { display: flex; padding: var(--spacing-sm) var(--spacing-sm); white-space: nowrap; gap: var(--spacing-base); }
.member { display: inline-flex; flex-direction: column; align-items: center; gap: 4rpx; min-width: 100rpx; }
.member-name { font-size: var(--font-size-xs); color: var(--color-text-secondary); max-width: 100rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.member-balance { font-size: var(--font-size-xs); font-weight: bold; }
.earn { color: var(--color-secondary); }
.lose { color: var(--color-danger); }
.invite-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--spacing-sm) var(--spacing-base); border-left: 1rpx solid var(--color-border); flex-shrink: 0; gap: 4rpx; }
.invite-icon { font-size: var(--font-size-xxl); color: var(--color-primary); line-height: 1; }
.invite-label { font-size: var(--font-size-xs); color: var(--color-primary); }

/* 消息列表 */
.messages { flex: 1; overflow: hidden; padding: var(--spacing-sm) var(--spacing-base); }
.message { background: var(--color-bg-white); border-radius: var(--radius-base); padding: var(--spacing-sm) var(--spacing-base); margin-bottom: var(--spacing-sm); display: flex; justify-content: space-between; align-items: center; }
.message-text { font-size: var(--font-size-sm); color: var(--color-text-primary); flex: 1; }
.message-actions { display: flex; gap: var(--spacing-sm); flex-shrink: 0; }
.msg-btn { font-size: var(--font-size-xs); padding: 4rpx 16rpx; border-radius: var(--radius-round); }
.revoke { background: #fff0ed; color: var(--color-danger); }
.thank { background: #f0f7ff; color: var(--color-primary); }
.msg-tag { font-size: var(--font-size-xs); color: var(--color-text-placeholder); }
.empty { text-align: center; color: var(--color-text-placeholder); padding: var(--spacing-xl) 0; font-size: var(--font-size-sm); }

/* 底部操作栏 */
.action-bar { display: flex; background: var(--color-bg-white); border-top: 1rpx solid var(--color-border); padding: var(--spacing-sm) 0; flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom); }
.action { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; font-size: var(--font-size-xs); color: var(--color-text-secondary); }
.action-icon { font-size: 36rpx; line-height: 1; }
