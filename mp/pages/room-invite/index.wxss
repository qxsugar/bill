.container { padding: var(--spacing-base); }

.code-card {
  background: var(--gradient-primary);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg) var(--spacing-base);
  display: flex; flex-direction: column; align-items: center;
  box-shadow: var(--shadow-primary);
  margin: var(--spacing-base) 0 var(--spacing-lg);
}
.label { font-size: var(--font-size-sm); color: rgba(255, 255, 255, 0.82); margin-bottom: var(--spacing-base); }
.code { font-size: 96rpx; font-weight: 700; color: #fff; letter-spacing: 16rpx; line-height: 1.1; }
.tips { font-size: var(--font-size-sm); color: rgba(255, 255, 255, 0.78); margin-top: var(--spacing-base); text-align: center; }

.btns { display: flex; flex-direction: column; gap: var(--spacing-base); }
