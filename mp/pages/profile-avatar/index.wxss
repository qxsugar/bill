.container { padding: var(--spacing-base); }
.avatar-grid { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); margin-bottom: var(--spacing-lg); }
.avatar-item { width: 140rpx; height: 140rpx; border-radius: 50%; border: 4rpx solid transparent; display: flex; align-items: center; justify-content: center; background: var(--color-bg-white); }
.avatar-item.selected { border-color: var(--color-primary); }
.emoji { font-size: 72rpx; }
.btn-confirm { background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); }
