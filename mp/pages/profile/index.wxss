.container { padding: var(--spacing-base); padding-bottom: calc(110rpx + env(safe-area-inset-bottom) + var(--spacing-base)); }

/* 头像卡 */
.avatar-card {
  display: flex; flex-direction: column; align-items: center; gap: var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-base);
  padding: var(--spacing-lg) 0;
}
.change-tip { display: flex; align-items: center; gap: 6rpx; font-size: var(--font-size-sm); color: var(--color-primary); }

/* 表单卡 */
.form-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-base);
  margin-top: var(--spacing-base);
  padding: 0 var(--spacing-base);
}
.form-item { display: flex; align-items: center; padding: var(--spacing-base) 0; }
.label { width: 120rpx; font-size: var(--font-size-base); color: var(--color-text-secondary); }
.input { flex: 1; font-size: var(--font-size-base); color: var(--color-text-primary); }
.placeholder { color: var(--color-text-placeholder); }

.save-btn { margin-top: var(--spacing-lg); }
