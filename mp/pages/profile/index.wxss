.container { padding: var(--spacing-base); }
.avatar-wrap { display: flex; flex-direction: column; align-items: center; padding: var(--spacing-lg) 0; }
.change-tip { font-size: var(--font-size-xs); color: var(--color-text-placeholder); margin-top: var(--spacing-xs); }
.form-item { display: flex; align-items: center; padding: var(--spacing-base); background: var(--color-bg-white); border-radius: var(--radius-base); margin-bottom: var(--spacing-sm); }
.label { width: 120rpx; font-size: var(--font-size-base); }
.input { flex: 1; }
.btn-save { margin-top: var(--spacing-lg); background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); }
