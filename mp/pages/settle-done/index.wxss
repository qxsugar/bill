.container { padding: var(--spacing-base); display: flex; flex-direction: column; align-items: center; }

.success-badge {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: var(--gradient-primary);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-primary);
  margin-top: var(--spacing-xl);
}
.success-text { display: block; font-size: var(--font-size-xl); font-weight: 700; margin: var(--spacing-base) 0 var(--spacing-lg); }

.members-list { width: 100%; margin-bottom: var(--spacing-lg); }
.member-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: var(--spacing-base);
  background: var(--color-bg-white);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-sm);
}
.nickname { font-size: var(--font-size-base); color: var(--color-text-primary); }
.balance { font-size: var(--font-size-md); }

.btns { display: flex; gap: var(--spacing-base); width: 100%; }
.btns .btn { flex: 1; }
