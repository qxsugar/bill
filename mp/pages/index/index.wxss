.container { padding: var(--spacing-base); }
.header { padding: var(--spacing-xl) 0 var(--spacing-lg); text-align: center; }
.title { font-size: var(--font-size-xxl); font-weight: bold; color: var(--color-primary); display: block; }
.subtitle { font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: var(--spacing-xs); }

.notice { display: flex; align-items: center; gap: var(--spacing-sm); background: var(--color-bg-white); border-radius: var(--radius-base); padding: var(--spacing-base); margin-top: var(--spacing-base); }
.notice-icon { font-size: var(--font-size-md); }
.notice-text { font-size: var(--font-size-sm); color: var(--color-text-secondary); flex: 1; }

.actions { display: flex; flex-direction: column; gap: var(--spacing-base); margin-top: var(--spacing-xl); }
.btn-primary { background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); font-size: var(--font-size-md); padding: var(--spacing-base); border: none; }
.btn-secondary { background: var(--color-bg-white); color: var(--color-primary); border-radius: var(--radius-lg); font-size: var(--font-size-md); padding: var(--spacing-base); border: 2rpx solid var(--color-primary); }

.tools { display: flex; gap: var(--spacing-base); margin-top: var(--spacing-xl); }
.tool-item { display: flex; flex-direction: column; align-items: center; gap: var(--spacing-xs); background: var(--color-bg-white); border-radius: var(--radius-base); padding: var(--spacing-md); min-width: 160rpx; }
.tool-icon { font-size: 48rpx; }
.tool-label { font-size: var(--font-size-sm); color: var(--color-text-primary); }
