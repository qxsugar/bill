<view class="container">
  <view class="header">
    <text class="title">打牌记账</text>
    <text class="subtitle">公平记分，不伤感情</text>
  </view>

  <view class="notice">
    <text class="notice-icon">📢</text>
    <text class="notice-text">{{notice}}</text>
  </view>

  <view class="actions">
    <button class="btn-primary" bindtap="createRoom">创建房间</button>
    <button class="btn-secondary" bindtap="joinRoom">加入房间</button>
  </view>

  <view class="tools">
    <view class="tool-item" bindtap="goCardTracker">
      <text class="tool-icon">🃏</text>
      <text class="tool-label">记牌器</text>
    </view>
  </view>
</view>
