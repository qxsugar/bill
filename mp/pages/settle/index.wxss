.container { padding: var(--spacing-base); }
.settle-list { margin-bottom: var(--spacing-lg); }
.settle-item {
  display: flex; align-items: center;
  padding: var(--spacing-base);
  background: var(--color-bg-white);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-sm);
}
.nickname { flex: 1; margin-left: var(--spacing-base); font-size: var(--font-size-base); color: var(--color-text-primary); }
.amount { font-size: var(--font-size-md); }
