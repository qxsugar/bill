.container { padding: var(--spacing-base); }
.settle-item { display: flex; justify-content: space-between; align-items: center; padding: var(--spacing-base); background: var(--color-bg-white); border-radius: var(--radius-base); margin-bottom: var(--spacing-sm); }
.earn { color: var(--color-secondary); }
.lose { color: var(--color-danger); }
.btn-confirm { margin-top: var(--spacing-lg); background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); }
