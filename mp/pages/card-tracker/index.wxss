.container { display: flex; flex-direction: column; min-height: 100vh; padding: var(--spacing-base); box-sizing: border-box; }

/* 剩余统计卡 */
.stat-card {
  background: var(--gradient-primary);
  border-radius: var(--radius-xl);
  padding: var(--spacing-md) var(--spacing-base);
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: var(--shadow-primary);
}
.stat-main { display: flex; align-items: baseline; gap: var(--spacing-xs); }
.stat-num { font-size: var(--font-size-display); font-weight: 700; color: #fff; line-height: 1; }
.stat-unit { font-size: var(--font-size-base); color: rgba(255, 255, 255, 0.82); }
.stat-deck {
  font-size: var(--font-size-sm); color: #fff;
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 20rpx; border-radius: var(--radius-round);
}

/* 工具栏 */
.toolbar { display: flex; gap: var(--spacing-sm); margin: var(--spacing-base) 0; }
.tool-picker { flex: 1; }
.tool-picker .tool-btn { width: 100%; }
.tool-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: var(--spacing-xs);
  background: var(--color-bg-white);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-sm) 0;
  font-size: var(--font-size-sm); color: var(--color-text-primary);
}
.tool-btn:active { transform: scale(0.97); }
.tool-btn.danger { color: var(--color-danger); }

/* 牌面网格 */
.card-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.card-cell {
  width: calc(20% - 12rpx);
  display: flex; flex-direction: column; align-items: center;
  background: var(--color-bg-white);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-sm) 0 12rpx;
  transition: transform 0.12s ease;
}
.card-cell:active { transform: scale(0.94); }
.card-cell.exhausted { opacity: 0.4; }
.card-display { font-size: var(--font-size-lg); font-weight: 700; color: var(--color-text-primary); }
.card-progress {
  width: 64%; height: 6rpx; border-radius: var(--radius-round);
  background: var(--color-bg-sunken); overflow: hidden; margin: 8rpx 0 6rpx;
}
.card-progress-bar { height: 100%; background: var(--color-primary); border-radius: var(--radius-round); transition: width 0.2s ease; }
.card-count { font-size: 22rpx; color: var(--color-text-placeholder); }

.hint {
  display: flex; align-items: center; justify-content: center; gap: var(--spacing-xs);
  font-size: var(--font-size-xs); color: var(--color-text-placeholder);
  margin-top: var(--spacing-base);
}
