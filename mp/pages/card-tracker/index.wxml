<view class="container">
  <!-- 剩余统计卡 -->
  <view class="stat-card">
    <view class="stat-main">
      <text class="stat-num">{{remaining}}</text>
      <text class="stat-unit">张剩余</text>
    </view>
    <view class="stat-deck">{{deckCount}} 副牌</view>
  </view>

  <view class="toolbar">
    <picker class="tool-picker" mode="selector" range="{{deckOptions}}" value="{{deckIndex}}" bindchange="onDeckChange">
      <view class="tool-btn">
        <icon name="settings" size="36" color="#3B5BDB" />
        <text>设置</text>
      </view>
    </picker>
    <view class="tool-btn danger" bindtap="resetCards">
      <icon name="reset" size="36" color="#E03131" />
      <text>重置</text>
    </view>
  </view>

  <view class="card-grid">
    <block wx:for="{{cards}}" wx:key="rank">
      <view class="card-cell {{item.count === 0 ? 'exhausted' : ''}}" bindtap="onCardTap" data-rank="{{item.rank}}">
        <text class="card-display">{{item.display}}</text>
        <view class="card-progress">
          <view class="card-progress-bar" style="width:{{item.count / item.max * 100}}%"></view>
        </view>
        <text class="card-count">{{item.count}}/{{item.max}}</text>
      </view>
    </block>
  </view>

  <view class="hint">
    <icon name="expense" size="28" color="#ADB2BD" />
    <text>单击 -1，快速双击 +1</text>
  </view>
</view>
