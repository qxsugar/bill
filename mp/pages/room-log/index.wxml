<view class="container">
  <scroll-view class="log-list" scroll-y enhanced show-scrollbar="{{false}}">
    <block wx:for="{{logs}}" wx:key="id">
      <view class="log-item">
        <view class="log-dot"></view>
        <view class="log-body">
          <text class="log-content">{{item.content}}</text>
          <text class="log-time">{{item.time}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!loading && logs.length === 0}}" class="empty-state">
      <icon name="log" size="72" color="#DCE0E8" />
      <text>暂无记录</text>
    </view>
  </scroll-view>
</view>
